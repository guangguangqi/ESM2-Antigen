def train_one_epoch():

    model.train()

    total_loss = 0

    for ab_tokens, ag_tokens, ag_adj, target_tokens in train_loader:

        ab_tokens = ab_tokens.to(device)
        ag_tokens = ag_tokens.to(device)
        ag_adj = ag_adj.to(device)
        target_tokens = target_tokens.to(device)

        optimizer.zero_grad()

        tgt_input = target_tokens[:, :-1]
        tgt_labels = target_tokens[:, 1:]

        logits = model(
            ab_tokens,
            ag_tokens,
            ag_adj,
            tgt_input
        )

        loss = criterion(
            logits.reshape(-1, 33),
            tgt_labels.reshape(-1)
        )

        loss.backward()

        optimizer.step()

        total_loss += loss.item()

    return total_loss / len(train_loader)


############################################################
# Validation
############################################################

def validate():

    model.eval()

    total_loss = 0

    with torch.no_grad():

        for ab_tokens, ag_tokens, ag_adj, target_tokens in val_loader:

            ab_tokens = ab_tokens.to(device)
            ag_tokens = ag_tokens.to(device)
            ag_adj = ag_adj.to(device)
            target_tokens = target_tokens.to(device)

            tgt_input = target_tokens[:, :-1]
            tgt_labels = target_tokens[:, 1:]

            logits = model(
                ab_tokens,
                ag_tokens,
                ag_adj,
                tgt_input
            )

            loss = criterion(
                logits.reshape(-1, 33),
                tgt_labels.reshape(-1)
            )

            total_loss += loss.item()

    return total_loss / len(val_loader)

############################################################
# Main Training Loop
############################################################

max_epochs = 50
best_val_loss = float("inf")

patience = 5
counter = 0

for epoch in range(max_epochs):

    train_loss = train_one_epoch()

    val_loss = validate()

    print(
        f"Epoch {epoch} | Train Loss {train_loss:.4f} | Val Loss {val_loss:.4f}"
    )

    if val_loss < best_val_loss:

        best_val_loss = val_loss

        counter = 0

        torch.save(
            model.state_dict(),
            "best_antibody_model.pt"
        )

    else:

        counter += 1

    if counter >= patience:

        print("Early stopping triggered")

        break


