import torch
import torch.nn as nn
from transformers import EsmModel, AutoTokenizer
from torch.utils.data import Dataset, DataLoader, random_split

############################################################
# Model
############################################################

class AntibodyGenerator(nn.Module):
    def __init__(self, esm_model_name="facebook/esm2_t6_8M_UR50D"):
        super().__init__()

        self.esm = EsmModel.from_pretrained(esm_model_name)
        self.embed_dim = self.esm.config.hidden_size

        self.antigen_gnn = nn.Sequential(
            nn.Linear(self.embed_dim, self.embed_dim),
            nn.ReLU(),
            nn.Linear(self.embed_dim, self.embed_dim)
        )

        self.cross_attention = nn.MultiheadAttention(
            embed_dim=self.embed_dim, num_heads=8, batch_first=True
        )

        decoder_layer = nn.TransformerDecoderLayer(
            d_model=self.embed_dim, nhead=8, batch_first=True
        )

        self.decoder = nn.TransformerDecoder(decoder_layer, num_layers=4)

        self.fc_out = nn.Linear(self.embed_dim, 33)

    def generate_causal_mask(self, sz, device):

        mask = torch.triu(torch.ones(sz, sz, device=device))
        mask = mask.masked_fill(mask == 1, float('-inf'))
        mask = mask.masked_fill(mask == 0, float(0.0))
        return mask

    def forward(self, ab_tokens, ag_tokens, ag_adj, target_tokens):

        ab_feats = self.esm(ab_tokens).last_hidden_state

        ag_feats = self.esm(ag_tokens).last_hidden_state

        ag_struct_feats = torch.matmul(ag_adj, ag_feats)

        ag_context = self.antigen_gnn(ag_struct_feats)

        interacted_feats, _ = self.cross_attention(
            ab_feats, ag_context, ag_context
        )

        tgt_emb = self.esm.embeddings.word_embeddings(target_tokens)

        sz = target_tokens.size(1)
        mask = self.generate_causal_mask(sz, target_tokens.device)

        output = self.decoder(
            tgt=tgt_emb,
            memory=interacted_feats,
            tgt_mask=mask
        )

        return self.fc_out(output)

############################################################
# Dataset
############################################################

class AntibodyDataset(Dataset):

    def __init__(self, database):
        self.database = database

    def __len__(self):
        return len(self.database)

    def __getitem__(self, idx):

        ab_seq, ag_seq, ag_adj, target_seq = self.database[idx]

        return ab_seq, ag_seq, ag_adj, target_seq

############################################################
# Collate function (handles batch tokenization)
############################################################

def collate_fn(batch):

    ab_seqs = [x[0] for x in batch]
    ag_seqs = [x[1] for x in batch]
    ag_adj = [x[2] for x in batch]
    target_seqs = [x[3] for x in batch]

    ab_tokens = tokenizer(
        ab_seqs,
        return_tensors="pt",
        padding=True
    ).input_ids

    ag_tokens = tokenizer(
        ag_seqs,
        return_tensors="pt",
        padding=True
    ).input_ids

    target_tokens = tokenizer(
        target_seqs,
        return_tensors="pt",
        padding=True
    ).input_ids

    max_len = ag_tokens.shape[1]

    padded_adj = []

    for adj in ag_adj:

        pad = torch.zeros(max_len, max_len)
        pad[:adj.shape[0], :adj.shape[1]] = adj
        padded_adj.append(pad)

    ag_adj = torch.stack(padded_adj)

    return ab_tokens, ag_tokens, ag_adj, target_tokens

