############################################################
# 5. Inference: Generate New Sequences
############################################################

def generate_candidates(model, ag_seq, ag_adj, num_samples=10, max_len=40):
    model.eval()
    candidates = []
    
    # Pre-process Antigen
    ag_tokens = tokenizer(ag_seq, return_tensors="pt").input_ids.to(device)
    ag_adj = ag_adj.to(device).unsqueeze(0) # Add batch dim

    with torch.no_grad():
        for _ in range(num_samples):
            # Start with <cls> token
            generated = torch.tensor([[tokenizer.cls_token_id]], device=device)
            
            for _ in range(max_len):
                # We use a dummy ab_seq for context, or a 'seed' framework
                dummy_ab = torch.zeros_like(ag_tokens) 
                
                logits = model(dummy_ab, ag_tokens, ag_adj, generated)
                next_token_logits = logits[:, -1, :]
                
                # Sample using Temperature (0.8 = creative, 0.1 = strict)
                probs = torch.softmax(next_token_logits / 0.8, dim=-1)
                next_token = torch.multinomial(probs, num_samples=1)
                
                generated = torch.cat((generated, next_token), dim=1)
                
                if next_token.item() == tokenizer.eos_token_id:
                    break
            
            candidates.append(tokenizer.decode(generated[0], skip_special_tokens=True))
    return list(set(candidates)) # Return unique sequences

