import torch
import torch.nn as nn
from transformers import EsmModel, AutoTokenizer
from torch.utils.data import Dataset, DataLoader, random_split

############################################################
# 1. Model: AntibodyGenerator
############################################################

class AntibodyGenerator(nn.Module):
    def __init__(self, esm_model_name="facebook/esm2_t6_8M_UR50D", freeze_layers=2):
        super().__init__()
        
        # Load Pre-trained ESM-2
        self.esm = EsmModel.from_pretrained(esm_model_name)
        self.embed_dim = self.esm.config.hidden_size # 320 for 8M model

        # OPTIMIZATION: Freeze early ESM layers to speed up inner-loop training
        if freeze_layers > 0:
            for param in self.esm.embeddings.parameters():
                param.requires_grad = False
            for layer in self.esm.encoder.layer[:freeze_layers]:
                for param in layer.parameters():
                    param.requires_grad = False

        # Structural GNN (Antigen Surface Mapping)
        self.antigen_gnn = nn.Sequential(
            nn.Linear(self.embed_dim, self.embed_dim),
            nn.ReLU(),
            nn.Linear(self.embed_dim, self.embed_dim)
        )

        # Cross-Attention (Binding Alignment)
        self.cross_attention = nn.MultiheadAttention(
            embed_dim=self.embed_dim, num_heads=8, batch_first=True
        )

        # Autoregressive Decoder
        decoder_layer = nn.TransformerDecoderLayer(
            d_model=self.embed_dim, nhead=8, batch_first=True
        )
        self.decoder = nn.TransformerDecoder(decoder_layer, num_layers=4)

        # Vocabulary Head (ESM-2 standard is 33 tokens)
        self.fc_out = nn.Linear(self.embed_dim, 33)

    def generate_causal_mask(self, sz, device):
        """
        FIXED: Creates a lower-triangular mask. 
        Positions with -inf are ignored, ensuring the model cannot 'see' the future.
        """
        mask = torch.triu(torch.ones(sz, sz, device=device), diagonal=1)
        mask = mask.masked_fill(mask == 1, float('-inf'))
        return mask

    def forward(self, ab_tokens, ag_tokens, ag_adj, target_tokens):
        # 1. Feature Extraction
        ab_feats = self.esm(ab_tokens).last_hidden_state
        ag_feats = self.esm(ag_tokens).last_hidden_state

        # 2. Structural Integration
        ag_struct_feats = torch.matmul(ag_adj, ag_feats)
        ag_context = self.antigen_gnn(ag_struct_feats)

        # 3. Cross-Attention
        interacted_feats, _ = self.cross_attention(
            query=ab_feats, key=ag_context, value=ag_context
        )

        # 4. Decoding with Causal Masking
        tgt_emb = self.esm.embeddings.word_embeddings(target_tokens)
        sz = target_tokens.size(1)
        mask = self.generate_causal_mask(sz, target_tokens.device)

        output = self.decoder(
            tgt=tgt_emb, 
            memory=interacted_feats, 
            tgt_mask=mask
        )

        return self.fc_out(output)

############################################################
# 2. Dataset & Collate (Data Handling)
############################################################

class AntibodyDataset(Dataset):
    def __init__(self, database):
        self.database = database # List of (ab_seq, ag_seq, ag_adj, target_seq)

    def __len__(self):
        return len(self.database)

    def __getitem__(self, idx):
        return self.database[idx]

def collate_fn(batch):
    ab_seqs, ag_seqs, ag_adjs, target_seqs = zip(*batch)

    # Tokenize sequences
    ab_tokens = tokenizer(ab_seqs, return_tensors="pt", padding=True).input_ids
    ag_tokens = tokenizer(ag_seqs, return_tensors="pt", padding=True).input_ids
    target_tokens = tokenizer(target_seqs, return_tensors="pt", padding=True).input_ids

    # Pad Adjacency Matrices to match max antigen length in this batch
    max_ag_len = ag_tokens.shape[1]
    padded_adj = []
    for adj in ag_adjs:
        pad = torch.zeros(max_ag_len, max_ag_len)
        pad[:adj.shape[0], :adj.shape[1]] = adj
        padded_adj.append(pad)
    
    return ab_tokens, ag_tokens, torch.stack(padded_adj), target_tokens

############################################################
# 3. Training/Validation Loop (The Inner Loop)
############################################################

def train_one_epoch(model, loader, optimizer, criterion, device):
    model.train()
    total_loss = 0
    for ab_tokens, ag_tokens, ag_adj, target_tokens in loader:
        ab_tokens, ag_tokens, ag_adj, target_tokens = [t.to(device) for t in [ab_tokens, ag_tokens, ag_adj, target_tokens]]

        optimizer.zero_grad()

        # Teacher Forcing: Shift tokens
        tgt_input = target_tokens[:, :-1]
        tgt_labels = target_tokens[:, 1:]

        logits = model(ab_tokens, ag_tokens, ag_adj, tgt_input)
        
        # Loss calculation (flattening B x L x V to (B*L) x V)
        loss = criterion(logits.reshape(-1, 33), tgt_labels.reshape(-1))
        
        loss.backward()
        optimizer.step()
        total_loss += loss.item()
    return total_loss / len(loader)

