# 4. SAMPLING LOGIC (Step 2: Gibbs Sampling)
# ==========================================
def generate_conditioned_sequences(model, tokenizer, template, ag_coords, 
                                 num_seqs=5000, temp=1.2, motif_constraints=None):
    model.eval()
    inputs = tokenizer(template, return_tensors="pt").to("cuda")
    mask_idx = (inputs.input_ids == tokenizer.mask_token_id).nonzero(as_tuple=True)[1]
    
    # Repeat for batch processing
    batch_ids = inputs.input_ids.repeat(num_seqs, 1).to("cuda")
    ag_coords = ag_coords.repeat(num_seqs, 1, 1).to("cuda")

    with torch.no_grad():
        # Step-by-step Gibbs Sampling
        for m_idx in mask_idx:
            logits = model.get_logits(batch_ids, ag_coords)
            token_logits = logits[:, m_idx, :] / temp
            
            # Apply Motif Constraints (e.g., force a specific AA at a position)
            if motif_constraints and m_idx.item() in motif_constraints:
                target_aa = motif_constraints[m_idx.item()]
                target_id = tokenizer.convert_tokens_to_ids(target_aa)
                next_tokens = torch.full((num_seqs,), target_id).to("cuda")
            else:
                probs = F.softmax(token_logits, dim=-1)
                next_tokens = torch.multinomial(probs, num_samples=1).squeeze()
            
            batch_ids[:, m_idx] = next_tokens

    return [tokenizer.decode(g, skip_special_tokens=True).replace(" ", "") for g in batch_ids]

