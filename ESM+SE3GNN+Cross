        ab_hidden = outputs.last_hidden_state # [1, Ab_Len, 1280]
        
        # C. Condition the Antibody on the 3D Antigen Context
        # This is where the 3D info is "injected"
        conditioned_h = self.cross_attn(ab_hidden, ag_context)
        
        # D. Predict Masked Tokens
        logits = self.esm_model.lm_head(conditioned_h)
        return logits
