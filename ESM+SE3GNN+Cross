def cluster_sequences(sequences, identity_threshold=0.8):
    # 1. 将生成的序列写入临时 FASTA 文件
    with open("candidates.fasta", "w") as f:
        for i, seq in enumerate(sequences):
            f.write(f">seq_{i}\n{seq}\n")
    
    # 2. 调用 MMseqs2 进行易用聚类 (easy-cluster)
    # 参数说明: --min-seq-id 为同一簇的最低相似度
    cmd = f"mmseqs easy-cluster candidates.fasta cluster_out tmp --min-seq-id {identity_threshold} -c 0.8"
    subprocess.run(cmd, shell=True, check=True)
    
    # 3. 读取聚类结果，仅提取每个簇的代表性序列 (Representative sequences)
    # cluster_out_rep_seq.fasta 包含了去冗余后的核心候选序列
    with open("cluster_out_rep_seq.fasta", "r") as f:
        representative_seqs = [line.strip() for line in f if not line.startswith(">")]
        
    return representative_seqs

