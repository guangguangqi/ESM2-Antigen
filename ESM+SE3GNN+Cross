在抗体设计中，使用 ESM-2 这种掩码语言模型（Masked Language Model, MLM）进行序列生成，核心逻辑是**“填空”**。 
以下是实现这一过程的 Python 代码示例，基于 Hugging Face Transformers 框架。
核心代码实现：基于掩码的 CDR 生成 
这段代码展示了如何加载 ESM-2 (650M参数版本)，并对特定的 CDR-H3 区域进行“条件采样”生成。
python
import torch
from transformers import AutoTokenizer, EsmForMaskedLM
import torch.nn.functional as F

# 1. 加载模型和分词器 (推荐使用 650M 或 3B 版本以保证质量)
model_name = "facebook/esm2_t33_650M_UR50D"
tokenizer = AutoTokenizer.from_pretrained(model_name)
model = EsmForMaskedLM.from_pretrained(model_name).cuda().eval()

# 2. 准备带 Mask 的抗体框架序列
# 假设我们保留 Framework，但要重新生成 CDR-H3 (用 <mask> 占位)
# 这里的 '<mask>' 数量代表你想要生成的 CDR 长度
scaffold_prefix = "EVQLVESGGGLVQPGGSLRLSCAASGFTFSSY" # Framework 1 & CDR1/2 简化示例
cdr_h3_mask = "<mask>" * 12                     # 假设生成 12 氨基酸长度的 H3
scaffold_suffix = "WGQGTLVTVSS"                  # Framework 4
full_template = scaffold_prefix + cdr_h3_mask + scaffold_suffix

def generate_sequences(template, num_to_generate=5000, temperature=1.0):
    inputs = tokenizer(template, return_tensors="pt").to("cuda")
    mask_indices = (inputs.input_ids == tokenizer.mask_token_id).nonzero(as_tuple=True)[1]
    
    generated_ids = inputs.input_ids.repeat(num_to_generate, 1)
    
    # 3. 逐步采样 (Gibbs Sampling 逻辑)
    with torch.no_grad():
        # 遍历每一个被 mask 的位置进行填充
        for idx in mask_indices:
            logits = model(generated_ids).logits
            mask_token_logits = logits[:, idx, :]
            
            # 应用温度系数控制多样性
            probs = F.softmax(mask_token_logits / temperature, dim=-1)
            
            # 从概率分布中采样下一个氨基酸
            next_tokens = torch.multinomial(probs, num_samples=1).squeeze()
            generated_ids[:, idx] = next_tokens
            
    # 解码为氨基酸序列
    return [tokenizer.decode(g, skip_special_tokens=True).replace(" ", "") for g in generated_ids]

# 执行生成 (示例生成 10 条查看效果)
results = generate_sequences(full_template, num_to_generate=10, temperature=1.2)
for i, seq in enumerate(results):
    print(f"Candidate {i+1}: {seq}")
